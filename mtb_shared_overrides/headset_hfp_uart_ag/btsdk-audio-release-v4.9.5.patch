+/*
+ * Optional app-side bridge hook for the btstack-v1 AG library.
+ * Keep this hook narrow: it only exposes CLCC requests so app firmware can
+ * answer the car's current-call-list query without making the HCI host own it.
+ */
+__attribute__((weak)) void hci_control_ag_bridge_on_clcc_req( uint16_t handle )
+{
+    (void)handle;
+}
